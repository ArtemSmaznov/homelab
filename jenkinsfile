pipeline {
  agent {
    label 'master'
  }

  options {
    timeout( time: 30, unit: 'MINUTES' )
  }

  stages {
    stage('Main') {
      steps {
        script {
          print "Hello, World!"
          sh "curl https://hub.docker.com/v2/repositories/jenkins/jenkins/tags"
        }
      }
    }
  }
}
