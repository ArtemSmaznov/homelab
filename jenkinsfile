pipeline {
    agent {
        label 'master'
    }

    options {
        timeout( time: 30, unit: 'MINUTES' )
    }

    stages {
        stage('Main') {
            steps {
                script {
                    list_versioned_containers()
                }
            }
        }
    }
}


def list_versioned_containers() {
    def repository = "jenkins/jenkins"
    list_version_tags(repository)
}

def list_version_tags(repository) {
    def tags_json = sh(
        returnStdout: true,
        script: "curl https://hub.docker.com/v2/repositories/${repository}/tags"
    )

    def tags = readJSON(text: tags_json)

    def results = []
    tags.results.each { tag ->
        results.add(tag.name)
    }

    print "${repository} version tags: \n ${results.join('\n ')}"
}
