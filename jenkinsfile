pipeline {
    agent {
        label 'master'
    }

    options {
        timeout( time: 30, unit: 'MINUTES' )
    }

    stages {
        stage('Main') {
            steps {
                script {
                    list_versioned_containers()
                }
            }
        }
    }
}


def list_versioned_containers() {
    list_current_versions()

    def repository = "jenkins/jenkins"
    list_version_tags(repository)
}

def list_current_versions() {
    def docker_compose = readYaml(file: "docker-compose.yml")

    def versions = []
    for (container in docker_compose.services) { 
        versions.add(container.getClass())
    }

    println "Current version tags: \n ${versions.join('\n ')}"
}

def list_version_tags(repository) {
    def tags_json = sh(
        returnStdout: true,
        script: "curl https://hub.docker.com/v2/repositories/${repository}/tags"
    )

    def tags = readJSON(text: tags_json)

    def results = []
    tags.results.each { tag ->
        results.add(tag.name)
    }

    println "${repository} version tags: \n ${results.join('\n ')}"
}
