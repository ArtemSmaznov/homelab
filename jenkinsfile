def testing() {
  def repository = "jenkins/jenkins"
  def tags_json = sh(
    returnStdout: true,
    script: "curl https://hub.docker.com/v2/repositories/${repository}/tags"
  )

  def tags = readJSON text: tags_json

  tags.results.each { tag ->
    println tag.name
  }

}

pipeline {
  agent {
    label 'master'
  }

  options {
    timeout( time: 30, unit: 'MINUTES' )
  }

  stages {
    stage('Main') {
      steps {
        script {
          testing()
        }
      }
    }
  }
}
